{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "credentialsSource": "remote"
      },
      "distribution": "internal",
      "autoIncrement": false,
      "withoutCredentials": false
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      },
      "distribution": "store"
    }
  }
}
